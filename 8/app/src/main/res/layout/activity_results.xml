<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/app_space_lg">

    <LinearLayout
        android:id="@+id/modeButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/app_space_sm"
        android:paddingBottom="@dimen/app_space_sm"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_back"
            style="@style/Widget.App.Button.MainButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Назад" />

        <Space
            android:layout_width="@dimen/app_space_sm"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_result"
            style="@style/Widget.App.Button.MainButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Результат" />

        <Space
            android:layout_width="@dimen/app_space_sm"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_all"
            style="@style/Widget.App.Button.MainButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Все" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/app_space_sm"
        android:text="Результаты"
        android:textAppearance="@style/TextAppearance.App.Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/modeButtons"/>

    <!-- Шапка таблицы -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.60"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/g2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.80"/>

    <TextView
        android:id="@+id/tvColSubject"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/app_space_md"
        android:text="Предмет"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/g1"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle"/>

    <TextView
        android:id="@+id/tvColMin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/app_space_md"
        android:text="Мин"
        android:textStyle="bold"
        android:gravity="end"
        app:layout_constraintStart_toStartOf="@id/g1"
        app:layout_constraintEnd_toStartOf="@id/g2"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle"/>

    <TextView
        android:id="@+id/tvColEntered"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/app_space_md"
        android:text="Введено"
        android:textStyle="bold"
        android:gravity="end"
        app:layout_constraintStart_toStartOf="@id/g2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle"/>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/app_space_sm"
        android:background="#1F000000"
        app:layout_constraintTop_toBottomOf="@id/tvColSubject"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="@dimen/app_space_sm"
        android:paddingBottom="@dimen/app_space_md"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toTopOf="@+id/tvAuthor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvAuthor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Бауэр Р. А., Т-423901-НТ"
        android:layout_marginTop="@dimen/app_space_sm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>